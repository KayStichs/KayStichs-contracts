{
  "$schema": "https://kaystichs.dev/schemas/wasm-info-v1.json",
  "brand": {
    "name": "KayStichs",
    "slug": "kaystichs",
    "reserve_casing": "KAYSTICHS",
    "version": "1.0.0",
    "repository": "kaystichs/kaystichs-contracts"
  },
  "workspace": {
    "root": "contracts/",
    "members": [
      "course-registry",
      "quest-engine",
      "reward-pool",
      "badge-nft",
      "governance",
      "stake-vault"
    ],
    "soroban_sdk": "23"
  },
  "build": {
    "target": "wasm32-unknown-unknown",
    "release_target": "wasm32v1-none",
    "tool": "stellar contract build",
    "tool_version": ">=v23.0.1"
  },
  "ci": {
    "formatting": "cargo fmt --all -- --check",
    "linting": "cargo clippy --all-targets --all-features -- -D warnings",
    "tests": "cargo test",
    "rebrand_verification": "scripts/verify-rebrand.sh"
  },
  "scripts": {
    "check_tools": "scripts/check-tools.sh",
    "test": "scripts/test.sh",
    "lint": "scripts/lint.sh",
    "build": "scripts/build.sh",
    "verify_rebrand": "scripts/verify-rebrand.sh"
  },
  "toolchain": {
    "rustfmt_config": "rustfmt.toml",
    "clippy_config": "clippy.toml"
  },
  "brand_assets": {
    "primary_color": "#4F46E5",
    "accent_color": "#F43F5E",
    "primary_dark": "#1E1B4B"
  },
  "release": {
    "playbook": "RELEASING.md",
    "versioning": "semver 2.0.0",
    "changelog_format": "keep-a-changelog 1.1.0"
  }
}
